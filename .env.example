# RSWS 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件不要提交到版本控制

# 数据库连接URL
RSWS_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/epusdt_rust

# Redis连接URL
RSWS_REDIS_URL=redis://127.0.0.1:6379

# 加密密钥（32字节）
RSWS_ENCRYPTION_KEY=change-this-32-byte-encryption-k

# 服务器配置（可选，默认值在config.toml中）
# RSWS_SERVER_HOST=127.0.0.1
# RSWS_SERVER_PORT=8080
# RSWS_SERVER_CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
