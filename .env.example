# ==============================
# RSWS_V1 Environment Variables
# ==============================
# Copy this file to .env and fill in your values.

# ---- Server ----
RSWS_SERVER_HOST=0.0.0.0
RSWS_SERVER_PORT=5170

# ---- PostgreSQL ----
POSTGRES_DB=rsws
POSTGRES_USER=rsws
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432
RSWS_DATABASE_URL=postgresql://rsws:change_me_strong_password@localhost:5432/rsws

# ---- Redis ----
REDIS_PASSWORD=change_me_redis_password
REDIS_PORT=6379
RSWS_REDIS_URL=redis://:change_me_redis_password@localhost:6379

# ---- Logging ----
RUST_LOG=info
RSWS_APP_LOG_LEVEL=info

# ---- Encryption ----
# 32-byte key for sensitive data encryption (hex or base64 encoded)
ENCRYPTION_KEY=change_me_32_byte_key_here!!!!

# ---- Deployment ----
IMAGE_VERSION=dev

# ---- Notes ----
# Config prefix: RSWS, separator: single underscore (_)
# RSWS_DATABASE_URL overrides config.toml's [database].url
# RSWS_REDIS_URL overrides config.toml's [redis].url
# The following configs are managed via database (system_configs table):
# - PayPal, USDT/Blockchain, Email, API Key, Security, System, Payment, Resource, Log, Notification
# Configure them through the admin API after initial setup.
