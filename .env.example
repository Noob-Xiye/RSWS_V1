# ==============================
# RSWS_V1 Environment Variables
# ==============================
# Copy this file to .env and fill in your values.

# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=5170

# ---- PostgreSQL ----
POSTGRES_DB=rsws
POSTGRES_USER=rsws
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432
# Full connection URL (used by rsws service in Docker)
RSWS_DATABASE_URL=postgresql://rsws:change_me_strong_password@postgres:5432/rsws

# ---- Redis ----
REDIS_PASSWORD=change_me_redis_password
REDIS_PORT=6379
# Full connection URL (used by rsws service in Docker)
RSWS_REDIS_URL=redis://:change_me_redis_password@redis:6379

# ---- Encryption ----
# 32-byte key for sensitive data encryption
ENCRYPTION_KEY=change_me_32_byte_key_here!!!!

# ---- Notes ----
# The following configs are managed via database (system_configs table):
# - PayPal, USDT/Blockchain, Email, API Key, Security, System, Payment, Resource, Log, Notification
# Configure them through the admin API after initial setup.
